---
// Динамическая страница роадмапа: `/<roadmapId>?tier=base|standard|hard`.
// Здесь мы:
// - читаем `roadmapId` из параметров маршрута
// - читаем `tier` из query string
// - генерируем структуру роадмапа (phases/topics) через generateRoadmap()
// - рендерим “таймлайн” + боковую панель с деталями темы
// - храним прогресс “изучено” в localStorage (только на клиенте)
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  generateRoadmap,
  type RoadmapTier,
  roadmapTiers,
} from '../../lib/roadmaps/generator';
import { subjects } from '../../lib/subjects';

export const prerender = false;

interface Params extends Record<string, string | undefined> {
  roadmapId: string;
}

const { roadmapId } = Astro.params as Params;
const subject = subjects.find((item) => item.id === roadmapId);
const tierParam = Astro.url.searchParams.get('tier') as RoadmapTier | null;
const tier = tierParam && tierParam in roadmapTiers ? tierParam : 'base';
const roadmap = generateRoadmap({ subjectId: roadmapId, tier });

const title = subject?.title || `Предмет: ${roadmapId}`;
const description =
  subject?.description || 'Дорожная карта подготовки по выбранному предмету.';

// Для боковой панели удобнее работать с плоским списком тем.
const allTopics =
  roadmap?.phases?.flatMap((phase) =>
    phase.topics.map((topic) => ({
      ...topic,
      phaseId: phase.id,
      phaseTitle: phase.title,
    })),
  ) || [];

// Прогресс хранится отдельно для каждого предмета и уровня сложности.
// Значение: список topic.id, отмеченных как “Изучено”.
const storageKey = `ege-roadmap:${roadmapId}:${tier}`;
---

<BaseLayout
  permalink={`/${roadmapId}`}
  title={title}
  description={description}
  noIndex={false}
>
  <div>
    <div class='roadmap-fullscreen py-8'>
      <h1 class='text-2xl font-bold sm:text-4xl'>{title}</h1>
      <p class='mt-2 text-gray-600'>{description}</p>

      <div class='mt-6 flex flex-wrap gap-2'>
        {
          (Object.keys(roadmapTiers) as RoadmapTier[]).map((tierKey) => {
            const config = roadmapTiers[tierKey];
            const isActive = tierKey === tier;
            return (
              <a
                class:list={[
                  'rounded-full border px-4 py-1 text-sm',
                  isActive
                    ? 'border-slate-900 bg-slate-900 text-white'
                    : 'border-slate-300 bg-white text-slate-700 hover:border-slate-400',
                ]}
                href={`/${roadmapId}?tier=${tierKey}`}
              >
                {config.label} · {config.goalScore}+
              </a>
            );
          })
        }
      </div>

      <div class='mt-6 rounded-lg border bg-white p-4'>
        <div class='flex items-center justify-between gap-3'>
          <div>
            <p class='text-xs uppercase tracking-wide text-slate-500'>
              Прогресс
            </p>
            <p class='text-lg font-semibold text-slate-900'>
              Изучено тем: <span data-progress-count>0</span> из{' '}
              <span data-progress-total>{allTopics.length}</span>
            </p>
          </div>
          <div class='text-right text-2xl font-bold text-slate-900'>
            <span data-progress-percent>0%</span>
          </div>
        </div>
        <div class='progress-track mt-3'>
          <div class='progress-fill' data-progress-bar></div>
        </div>
      </div>

      <div class='mt-6 rounded-lg border bg-white p-4'>
        <h2 class='text-lg font-semibold'>
          Дорожная карта: {roadmapTiers[tier].label}
        </h2>
        <p class='text-sm text-gray-500'>
          Выберите тему, чтобы увидеть детали и отметить прогресс.
        </p>

      <div class='roadmap-layout mt-6'>
          <div class='roadmap-overlay' data-roadmap-overlay></div>
          <aside class='roadmap-sidebar' data-roadmap-panel>
            <div class='roadmap-sidebar-header'>
              <p class='text-xs uppercase tracking-wide text-slate-500'>
                Детали темы
              </p>
              <button class='panel-close' data-panel-close type='button'>
                Закрыть
              </button>
            </div>
            <h3 class='text-lg font-semibold text-slate-900' data-panel-title>
              Выберите тему
            </h3>
            <p class='mt-2 text-sm text-slate-600' data-panel-description>
              Нажмите на любой блок в дорожной карте, чтобы открыть описание.
            </p>

            <div class='mt-4'>
              <p class='text-xs uppercase tracking-wide text-slate-500'>
                Полезные источники
              </p>
              <ul class='panel-links' data-panel-links></ul>
            </div>

            <button class='panel-action' data-panel-toggle type='button'>
              Изучено
            </button>
          </aside>

          <div class='roadmap-surface'>
          <div class='roadmap-map'>
          {
            roadmap?.phases?.map((phase) => {
              // UI раскладывает темы в две колонки “шахматкой”:
              // - чётные индексы слева
              // - нечётные справа
              // Это визуально помогает “читать” дорожную карту как таймлайн.
              const leftTopics = phase.topics.filter((_, i) => i % 2 === 0);
              const rightTopics = phase.topics.filter((_, i) => i % 2 !== 0);
              return (
                <div class='roadmap-row'>
                  <div class='roadmap-side roadmap-side-left'>
                    {leftTopics.map((topic) => (
                      <button
                        class='roadmap-node roadmap-node-left'
                        data-topic-id={topic.id}
                        type='button'
                      >
                        <div class='roadmap-node-card'>
                          <span
                            class='progress-check'
                            aria-hidden='true'
                          ></span>
                          <span class='text-sm'>{topic.title}</span>
                        </div>
                      </button>
                    ))}
                  </div>

                  <div class='roadmap-core'>
                    <div class='roadmap-core-card'>
                      <h3 class='text-base font-semibold'>{phase.title}</h3>
                      <p class='mt-1 text-xs text-slate-400'>
                        {phase.description}
                      </p>
                    </div>
                  </div>

                  <div class='roadmap-side roadmap-side-right'>
                    {rightTopics.map((topic) => (
                      <button
                        class='roadmap-node roadmap-node-right'
                        data-topic-id={topic.id}
                        type='button'
                      >
                        <div class='roadmap-node-card'>
                          <span
                            class='progress-check'
                            aria-hidden='true'
                          ></span>
                          <span class='text-sm'>{topic.title}</span>
                        </div>
                      </button>
                    ))}
                  </div>
                </div>
              );
            })
          }
          </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script
  is:inline
  define:vars={{
    storageKey,
    topics: allTopics,
  }}
>
  // Клиентский код отвечает за:
  // - открытие/закрытие боковой панели
  // - рендер ссылок по выбранной теме
  // - сохранение “изучено” в localStorage
  // - пересчет прогресса и подсветку выполненных тем
  const panel = document.querySelector('[data-roadmap-panel]');
  const overlay = document.querySelector('[data-roadmap-overlay]');
  const panelTitle = panel?.querySelector('[data-panel-title]');
  const panelDescription = panel?.querySelector('[data-panel-description]');
  const panelLinks = panel?.querySelector('[data-panel-links]');
  const panelToggle = panel?.querySelector('[data-panel-toggle]');
  const panelClose = panel?.querySelector('[data-panel-close]');

  const progressCount = document.querySelector('[data-progress-count]');
  const progressTotal = document.querySelector('[data-progress-total]');
  const progressPercent = document.querySelector('[data-progress-percent]');
  const progressBar = document.querySelector('[data-progress-bar]');

  const topicMap = new Map();
  for (const topic of topics) {
    topicMap.set(topic.id, topic);
  }

  // Считываем прогресс из localStorage.
  // Формат хранения: JSON-массив строк (topic.id).
  function getStoredProgress() {
    try {
      const raw = localStorage.getItem(storageKey);
      return raw ? new Set(JSON.parse(raw)) : new Set();
    } catch {
      return new Set();
    }
  }

  // Сохраняем Set обратно как массив (JSON не умеет сериализовать Set).
  function saveStoredProgress(progressSet) {
    localStorage.setItem(storageKey, JSON.stringify(Array.from(progressSet)));
  }

  let activeTopicId = null;
  let completed = getStoredProgress();

  function setPanelOpen(isOpen) {
    if (!panel || !overlay) return;
    panel.classList.toggle('panel-open', isOpen);
    overlay.classList.toggle('overlay-show', isOpen);
  }

  function updateProgressUI() {
    const total = topics.length;
    const done = completed.size;
    const percent = total === 0 ? 0 : Math.round((done / total) * 100);

    if (progressCount) progressCount.textContent = String(done);
    if (progressTotal) progressTotal.textContent = String(total);
    if (progressPercent) progressPercent.textContent = `${percent}%`;
    if (progressBar) progressBar.style.width = `${percent}%`;

    document.querySelectorAll('[data-topic-id]').forEach((node) => {
      const topicId = node.getAttribute('data-topic-id');
      if (!topicId) return;
      node.classList.toggle('topic-complete', completed.has(topicId));
    });
  }

  // Перерисовываем список ссылок в панели.
  // Если ссылок нет — показываем нейтральный плейсхолдер.
  function renderLinks(links = []) {
    if (!panelLinks) return;
    panelLinks.innerHTML = '';
    if (!links.length) {
      const li = document.createElement('li');
      li.textContent = 'Ссылки будут добавлены позже.';
      panelLinks.appendChild(li);
      return;
    }
    for (const link of links) {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = link.url;
      a.target = '_blank';
      a.rel = 'noreferrer';
      a.textContent = link.title;
      li.appendChild(a);
      panelLinks.appendChild(li);
    }
  }

  // Открываем панель для темы:
  // - выставляем заголовок/описание
  // - показываем список ссылок
  // - обновляем текст кнопки “Изучено”
  function openPanel(topicId) {
    const topic = topicMap.get(topicId);
    if (!topic || !panel) return;

    activeTopicId = topicId;
    setPanelOpen(true);
    if (panelTitle) panelTitle.textContent = topic.title;
    if (panelDescription) panelDescription.textContent = topic.description;
    renderLinks(topic.links);

    if (panelToggle) {
      const isDone = completed.has(topicId);
      panelToggle.textContent = isDone ? 'Отменить изучение' : 'Изучено';
    }
  }

  function closePanel() {
    setPanelOpen(false);
    activeTopicId = null;
  }

  // Клик по любому блоку темы в таймлайне открывает панель.
  document.querySelectorAll('[data-topic-id]').forEach((node) => {
    node.addEventListener('click', () => {
      const topicId = node.getAttribute('data-topic-id');
      if (!topicId) return;
      if (activeTopicId === topicId) {
        closePanel();
        return;
      }
      openPanel(topicId);
    });
  });

  // Переключатель “Изучено”: меняем Set, сохраняем и обновляем UI.
  panelToggle?.addEventListener('click', () => {
    if (!activeTopicId) return;
    if (completed.has(activeTopicId)) {
      completed.delete(activeTopicId);
    } else {
      completed.add(activeTopicId);
    }
    saveStoredProgress(completed);
    updateProgressUI();
    openPanel(activeTopicId);
  });

  panelClose?.addEventListener('click', closePanel);
  overlay?.addEventListener('click', closePanel);
  updateProgressUI();
</script>
