---
import Icon from './AstroIcon.astro';
---

<footer class='bg-white py-8 text-slate-600 border-t'>
  <div class='container flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between'>
    <a class='flex items-center gap-2 text-slate-900' href='/'>
      <img
        src='/favicon.ico'
        alt=''
        class='h-6 w-6'
        width='24'
        height='24'
        loading='lazy'
      />
      <span class='font-semibold'>Roadmaps</span>
    </a>

    <nav class='flex flex-wrap gap-4 text-sm'>
      <a class='hover:text-slate-900' href='/roadmaps'>Предметы</a>
      <a class='hover:text-slate-900' href='/about'>О проекте</a>
    </nav>

    <span class='text-xs text-slate-500'>
      ©Roadmaps
    </span>
  </div>
</footer>
