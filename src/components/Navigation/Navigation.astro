---
import Icon from '../AstroIcon.astro';

const links = [
  { href: '/roadmaps', label: 'Предметы' },
  { href: '/about', label: 'О проекте' },
];
---

<div class='navbar bg-blue-600 py-4 text-white shadow-sm'>
  <nav class='container flex items-center justify-between'>
    <a
      class='flex items-center gap-2 text-lg font-semibold text-white'
      href='/'
      aria-label='Roadmaps'
    >
      <img
        src='/favicon.ico'
        alt=''
        class='h-10 w-10'
        width='24'
        height='24'
        loading='eager'
      />
      <span>Roadmaps</span>
    </a>

    <ul class='flex items-center gap-4 text-sm text-white'>
      {
        links.map((link) => (
          <li>
            <a class='text-white hover:text-white' href={link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>
